# macOS cruft
.DS_Store
**/.DS_Store

# Local dev tooling (not part of the shipped app)
.claude/

# This repo is PUBLIC (GitHub Pages). Keep it to ONLY the shipped app — the
# planning docs and unused/future art stay local. (Decision: Phase 0.)
/_docs/
/_briefs/
/_reports/
/CLAUDE.md
/STATUS.md
/README.md
/assets/README.md

# assets/: publish ONLY the art the live game actually uses. Unused poses, the 5
# deferred zones, and reference frames stay private. (Pokémon sprites: private, above.)
/assets/*
!/assets/backgrounds
/assets/backgrounds/*
!/assets/backgrounds/bg-meadow.png
!/assets/backgrounds/bg-forest.png
!/assets/backgrounds/bg-beach.png
!/assets/backgrounds/bg-mountain.png
!/assets/backgrounds/bg-desert.png
!/assets/backgrounds/bg-volcano.png
!/assets/backgrounds/bg-snowfield.png
!/assets/backgrounds/bg-grove.png
!/assets/backgrounds/bg-cave.png
!/assets/backgrounds/bg-ocean.png
!/assets/screens
/assets/screens/*
!/assets/screens/screen-title.png
!/assets/screens/bg-lab.png
!/assets/screens/screen-worldmap.png
!/assets/screens/scene-starter-select.png
!/assets/screens/bg-evolution.png
!/assets/characters
/assets/characters/*
!/assets/characters/alex
/assets/characters/alex/*
!/assets/characters/alex/alex-ready.png
!/assets/characters/alex/alex-throwing.png
!/assets/characters/dada
/assets/characters/dada/*
!/assets/characters/dada/dada-greeting.png
!/assets/characters/dada/dada-cheering.png
!/assets/characters/mama
/assets/characters/mama/*
!/assets/characters/mama/mama-greeting.png
!/assets/characters/mama/mama-cheering.png
# UI icons + reward stickers (brief 6) — the live app uses these. Forward-ready:
# when Operations drops the cut PNGs in, they commit automatically.
!/assets/ui
/assets/ui/*
!/assets/ui/*.png
!/assets/stickers
/assets/stickers/*
!/assets/stickers/*.png
!/assets/cards
/assets/cards/*
!/assets/cards/*.png

# Build-time tooling (sprite fetch, audio manifest/generation) — local, not shipped.
/tools/

# NOTE: sprites are now PUBLISHED (founder decision 2026-06-19) so the live site
# shows real Pokémon. The Poké-Ball fallback (js/ui.js) stays as a safety net.
